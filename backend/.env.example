# App
PROJECT_NAME="AI Stock Trading Assistant"
API_V1_STR="/api/v1"
SECRET_KEY="your-super-secret-key-for-jwt-auth"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/stock_trading_ai"

# Redis & Celery
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# Brokers (e.g. Alpaca)
ALPACA_API_KEY=""
ALPACA_API_SECRET=""
ALPACA_BASE_URL="https://paper-api.alpaca.markets"

# AI Provider
OPENAI_API_KEY=""
AI_API_KEY=""

# Kafka
KAFKA_BOOTSTRAP_SERVERS="localhost:9092"
KAFKA_TOPIC_MARKET_TICKS="market.ticks"
KAFKA_TOPIC_TRADE_SIGNALS="trade.signals"
KAFKA_TOPIC_EXECUTIONS="trade.executions"
